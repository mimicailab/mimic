{
  "name": "@mimicai/core",
  "version": "0.7.0",
  "description": "Core engine for Mimic — persona-driven synthetic data generation, schema parsing, database seeding, and MCP server",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Mimic AI Lab",
  "homepage": "https://github.com/mimicailab/mimic",
  "repository": {
    "type": "git",
    "url": "https://github.com/mimicailab/mimic.git",
    "directory": "packages/core"
  },
  "keywords": [
    "synthetic-data",
    "mcp",
    "ai-agent",
    "testing",
    "database",
    "seeding"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.53",
    "@ai-sdk/openai": "^3.0.39",
    "@faker-js/faker": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@mrleebo/prisma-ast": "^0.12.0",
    "ai": "^6.0.107",
    "chalk": "^5.4.1",
    "fastify": "^5.7.4",
    "ora": "^8.2.0",
    "pgsql-parser": "^17.9.11",
    "seedrandom": "^3.0.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/seedrandom": "^3.0.8",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
