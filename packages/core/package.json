{
  "name": "@mimicailab/core",
  "version": "0.1.0",
  "description": "Core engine for Mimic — persona-driven synthetic data generation, schema parsing, database seeding, and MCP server",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Mimic AI Lab",
  "homepage": "https://github.com/mimicailab/mimic",
  "repository": {
    "type": "git",
    "url": "https://github.com/mimicailab/mimic.git",
    "directory": "packages/core"
  },
  "keywords": ["synthetic-data", "mcp", "ai-agent", "testing", "database", "seeding"],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.2",
    "ai": "^4.1.61",
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.22",
    "seedrandom": "^3.0.5",
    "@mrleebo/prisma-ast": "^0.12.0",
    "pgsql-parser": "^17.9.11",
    "pg": "^8.13.3",
    "pg-copy-streams": "^6.0.6",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "fastify": "^4.28.0",
    "chalk": "^5.4.1",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "vitest": "^3.0.5",
    "typescript": "^5.7.3",
    "@types/pg": "^8.11.11",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/seedrandom": "^3.0.8"
  }
}
