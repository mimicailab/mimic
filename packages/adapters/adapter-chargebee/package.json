{
  "name": "@mimicai/adapter-chargebee",
  "version": "0.9.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "mimic-mcp-chargebee": "./dist/bin/mcp.js"
  },
  "files": [
    "dist",
    "adapter.json",
    "logo.svg"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate": "tsx scripts/chargebee-codegen.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mimicai/adapter-sdk": "workspace:*",
    "@mimicai/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "fastify": "^5.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
