{
  "name": "@mimicai/adapter-plaid",
  "version": "0.10.0",
  "description": "Plaid API mock adapter for Mimic — banking, transactions, accounts, identity, auth",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Mimic AI Lab",
  "homepage": "https://github.com/mimicailab/mimic",
  "repository": {
    "type": "git",
    "url": "https://github.com/mimicailab/mimic.git",
    "directory": "packages/adapters/adapter-plaid"
  },
  "keywords": [
    "mimic",
    "adapter",
    "plaid",
    "api-mock",
    "banking",
    "transactions"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "adapter.json",
    "logo.svg"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate": "tsx scripts/plaid-codegen.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "bin": {
    "mimic-mcp-plaid": "./dist/bin/mcp.js"
  },
  "dependencies": {
    "@mimicai/adapter-sdk": "workspace:*",
    "@mimicai/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "fastify": "^5.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4",
    "yaml": "^2.7.1"
  }
}
