{
  "name": "@mimicai/adapter-sdk",
  "version": "0.11.1",
  "description": "SDK for building Mimic API mock adapters — base class, test helpers, and shared utilities",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Mimic AI Lab",
  "homepage": "https://github.com/mimicailab/mimic",
  "repository": {
    "type": "git",
    "url": "https://github.com/mimicailab/mimic.git",
    "directory": "packages/adapter-sdk"
  },
  "keywords": [
    "mimic",
    "adapter",
    "sdk",
    "api-mock",
    "testing"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@mimicai/core": "workspace:*",
    "fastify": "^5.8.2"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
