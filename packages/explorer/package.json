{
  "name": "@mimicai/explorer",
  "version": "0.7.1",
  "description": "Interactive web UI for exploring Mimic mock data and endpoints",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsup",
    "build:ui": "vite build",
    "build:server": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/static": "^8.1.0",
    "@fastify/cors": "^10.0.2",
    "@mimicai/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
