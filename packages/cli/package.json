{
  "name": "@mimicai/cli",
  "version": "0.11.1",
  "description": "CLI for Mimic — generate, seed, serve, and test synthetic data for AI agents",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Mimic AI Lab",
  "homepage": "https://github.com/mimicailab/mimic",
  "repository": {
    "type": "git",
    "url": "https://github.com/mimicailab/mimic.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "cli",
    "synthetic-data",
    "mcp",
    "ai-agent",
    "testing"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "mimic": "./dist/bin/mimic.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@mimicai/adapter-mongodb": "workspace:*",
    "@mimicai/adapter-mysql": "workspace:*",
    "@mimicai/adapter-postgres": "workspace:*",
    "@mimicai/adapter-sqlite": "workspace:*",
    "@mimicai/blueprints": "workspace:*",
    "@mimicai/core": "workspace:*",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "pg": "^8.20.0"
  },
  "optionalDependencies": {
    "@mimicai/adapter-chargebee": "workspace:*",
    "@mimicai/adapter-gocardless": "workspace:*",
    "@mimicai/adapter-lemonsqueezy": "workspace:*",
    "@mimicai/adapter-paddle": "workspace:*",
    "@mimicai/adapter-plaid": "workspace:*",
    "@mimicai/adapter-recurly": "workspace:*",
    "@mimicai/adapter-revenuecat": "workspace:*",
    "@mimicai/adapter-stripe": "workspace:*",
    "@mimicai/adapter-zuora": "workspace:*",
    "@mimicai/explorer": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
